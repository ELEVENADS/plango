key=XXX

# Nacos
NACOS_SERVER_ADDR=localhost:8848
NACOS_SERVICE_NAME=plan-agent
NACOS_SERVICE_IP=
NACOS_SERVICE_PORT=18000
NACOS_GROUP=DEFAULT_GROUP

# RAG — Embedding（OpenAI 兼容 API）
EMBEDDING_API_KEY=sk-xxx           # 为空时回退到 LLM_API_KEY
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# RAG — 检索参数
RETRIEVAL_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# RAG — Query 扩写
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_VARIANTS=3