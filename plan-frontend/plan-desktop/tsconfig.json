{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"],
      "@render/*": ["./src/render/*"],
    }
  },
  "include": ["src/main/**/*", "src/render/**/*", "global.d.ts"]
}

